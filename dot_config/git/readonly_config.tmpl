[branch]
	sort = -committerdate

[column]
	ui = auto

[commit]
	gpgSign = true

[core]
	autocrlf = input
	editor = vim

[diff]
	algorithm = histogram
	colorMoved = plain
	mnemonicPrefix = true
	renames = true

[fetch]
	prune = true
	pruneTags = true
	all = true

[filter "lfs"]
	clean = "git-lfs clean -- %f"
	process = "git-lfs filter-process"
	required = true
	smudge = "git-lfs smudge -- %f"

[gpg]
	format = ssh

[gpg "ssh"]
	program = "/Applications/1Password.app/Contents/MacOS/op-ssh-sign"
	allowedSignersFile = ~/.config/git/allowed_ssh_signers

[help]
	autocorrect = prompt

[init]
	defaultBranch = main

[pull]
	rebase = true

[push]
	autoSetupRemote = true
	default = simple
	followTags = true

[rebase]
	autoSquash = true
	autoStash = true
	updateRefs = true

[rerere]
	enabled = true
	autoupdate = true

[tag]
	gpgSign = false
	sort = version:refname

[user]
	email = {{ .email | quote }}
	name = {{ .name | quote }}
	signingKey = "ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHqKXp5NtCzOEeMwZM5msGRy0Jga70SnM0H7JZ0WHtML"
