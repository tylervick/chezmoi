#!/bin/zsh

# Powerlevel10k instant prompt. Keep at the very top of .zshrc, before anything
# that may produce console output. If it warns about output, move the offending
# init below the antidote load, or set POWERLEVEL9K_INSTANT_PROMPT=quiet.
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# zsh options
setopt HIST_FCNTL_LOCK        # Use OS X FCNTL locking to avoid race conditions when writing to history files
setopt HIST_IGNORE_DUPS
unsetopt HIST_IGNORE_ALL_DUPS
setopt HIST_IGNORE_SPACE      # Ignore commands that start with space
setopt HIST_EXPIRE_DUPS_FIRST # Expire duplicate entries first when trimming history
setopt SHARE_HISTORY          # Share history between all sessions
setopt EXTENDED_HISTORY       # Save each command's start timestamp and the duration to the history file after it was executed
setopt AUTO_CD                # type a dir path (../foo, somedir/) to cd into it

# use vim as default editor, cursor as visual editor
export VISUAL="cursor --wait"
export EDITOR="vim"

# Pin the ZLE keymap explicitly. zsh picks the main keymap once at startup from
# the *inherited* environment: viins if $EDITOR/$VISUAL contains "vi", else emacs.
# A top-level shell starts with EDITOR unset (→ emacs), but a nested shell (e.g.
# `chezmoi cd`, tmux panes, zsh-in-zsh) inherits the EDITOR=vim exported above and
# silently boots into vi mode, where backspace is vi-backward-delete-char. Pinning
# here makes line editing identical regardless of how the shell was launched.
bindkey -e

# ensure that path entries are unique
typeset -gU path cdpath fpath manpath

# Source zstyles you might use with antidote.
[[ -e ${ZDOTDIR:-$HOME}/.zstyles ]] && source ${ZDOTDIR:-$HOME}/.zstyles

# Autoload any functions in $ZFUNCDIR. Guard against an empty/absent dir:
# with no matches the glob vanishes, leaving a bare `autoload -Uz` that lists
# all autoload functions to stdout — which trips p10k's instant-prompt warning.
ZFUNCDIR=${ZDOTDIR:-$HOME}/functions
fpath=($ZFUNCDIR $fpath)
() {
  local fns=($ZFUNCDIR/*(N.:t))
  (( $#fns )) && autoload -Uz $fns
}

# source antidote from brew
[[ ! -f /opt/homebrew/opt/antidote/share/antidote/antidote.zsh ]] || source /opt/homebrew/opt/antidote/share/antidote/antidote.zsh
# TODO: determine fallback behavior
antidote load

# enable CTRL-T, ALT-C, CTRL-R & fuzzy completion from fzf
# fzf is installed via brew, but not easily available in antidote: https://github.com/mattmc3/antidote/issues/112
source <(fzf --zsh)

# history-substring-search key bindings (plugin is otherwise inert without these).
# Bind both terminfo codes and raw escape sequences for robustness across terminals.
bindkey "$terminfo[kcuu1]" history-substring-search-up
bindkey "$terminfo[kcud1]" history-substring-search-down
bindkey '^[[A' history-substring-search-up
bindkey '^[[B' history-substring-search-down

# Word-deletion ergonomics. Re-assert emacs keymap *after* antidote load: the
# bindkey -e near the top runs before plugins, and the keymap ends up back on
# viins by the first prompt (zsh auto-selects vi from EDITOR=vim). Pinning here
# makes option+delete map to backward-kill-word.
bindkey -e
# Treat path separators (/ . - etc.) as word boundaries so option+delete
# (^[^?) kills one path segment instead of the whole `~/.config/something`.
# Default WORDCHARS counts / . ~ as word chars, swallowing the entire path.
autoload -Uz select-word-style
select-word-style bash

# Named Directory Hashes
