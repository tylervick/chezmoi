#!/bin/zsh
#
# .aliases — curated interactive aliases & small functions
#
# Loaded as a local antidote plugin. Grouped by area. Prefer functions over
# aliases where logic/args are involved.
#

# ── Navigation ────────────────────────────────────────────────────────────────
alias -- -='cd -'
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'
alias .....='cd ../../../..'
alias 'cd..'='cd ..'
alias '~'='cd ~'

# ── Files & listing (modern CLI replacements) ───────────────────────────────────
alias ls='eza'
alias cat='bat'
alias du='dust'
alias df='duf'
alias cp='cp -v'
alias mv='mv -v'
alias rm='rm -i'
alias o='open'
alias oo='open .'
alias f='open .'
alias ungz='gunzip -k'

# ── Git ──────────────────────────────────────────────────────────────────────
# Resolve a repo's default branch from origin/HEAD (main, master, trunk, …).
# Falls back to "main". Requires origin/HEAD to be set:
#   git remote set-head origin --auto
git_default_branch() {
  local ref
  ref=$(git symbolic-ref --quiet refs/remotes/origin/HEAD 2>/dev/null) \
    && print -r -- "${ref#refs/remotes/origin/}" \
    || print -r -- main
}

alias g='git'
alias gs='git status'
alias gss='git status -s'
alias gd='git diff'
alias gl='git log'
alias glp5='git log -5 --pretty --oneline'
alias glsw='git log -S'                      # pickaxe: commits touching a string
alias glt='git log --all --graph --decorate --oneline --simplify-by-decoration'
alias gsl='git shortlog -sn'
alias gb='git branch'
alias gbr="git branch --no-color | sed -e '/^[^*]/d' -e 's/* \(.*\)/\1/'"  # current branch name
alias gc='git checkout'
alias gcm='git checkout "$(git_default_branch)"'
alias gcmp='b=$(git_default_branch); git checkout "$b" && git pull origin "$b"'
alias ggmp='git checkout -'                  # back to previous branch
alias gm='git commit -m'
alias gam='git commit -am'
alias gap='git add -p'
alias gp='git push origin HEAD'
alias gpo='git push origin'
alias gpt='git push origin HEAD && git push --tags'
alias gpu='git pull origin HEAD --prune'
alias gst='git stash'
alias gdtp='git stash pop'
alias gchp='git cherry-pick'
alias gcl='git clone'
alias gcln='git clean -xfd'
alias gf='git reflog'
alias gra='git remote add'
alias grr='git remote rm'
alias gta='git tag -a -m'
alias gws='git diff --shortstat "@{0 day ago}"'
alias lg='lazygit'
# WIP commit (no auto-push — push deliberately with gp).
alias wip='git add -A && git commit -m WIP'

# ── Docker / Kubernetes ─────────────────────────────────────────────────────────
alias d='docker'
alias dc='docker compose'
alias lzd='lazydocker'
alias k='kubectl'
alias kp='kubectl get pods'

# ── Network ─────────────────────────────────────────────────────────────────────
alias ip='dig +short myip.opendns.com @resolver1.opendns.com'   # public IP
alias localip='ipconfig getifaddr en0 || ipconfig getifaddr en1' # LAN IP (wifi/eth)
myip() { ifconfig | awk '/inet / && $2 != "127.0.0.1" { print $2 }' }
killport() { kill "$(lsof -t -i:"$1")" }

# ── macOS / system ───────────────────────────────────────────────────────────────
alias flushdns='sudo dscacheutil -flushcache && sudo killall -HUP mDNSResponder'
alias b64='pbpaste | base64 --decode'
alias sudo='sudo '   # trailing space lets the next word be alias-expanded too

# ── Editors ──────────────────────────────────────────────────────────────────────
alias v='vim'
