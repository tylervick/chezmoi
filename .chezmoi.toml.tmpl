# -*-mode:conf-toml-*- vim:ft=toml

# ~/.local/share/chezmoi/.chezmoi.toml.tmpl
# =============================================================================
# Used to customize configuration when doing a `chezmoi init`.
#
# Prompts for machine-specific values. The *Once helpers read any value
# already stored in ~/.config/chezmoi/chezmoi.toml on re-init, so re-running
# `chezmoi init` does NOT re-prompt. The resulting file is created at
# `~/.config/chezmoi/chezmoi.toml`.
# See https://www.chezmoi.io/docs/how-to/
#
# {{- /* This file supports Go's text/template language. */}}

# {{- $profile := promptChoiceOnce . "profile" "Machine profile" (list "work" "personal") }}
# {{- $hostname := promptStringOnce . "hostname" "hostname of the machine" }}

# {{- /* Profile-derived git identity. Work values are fixed; personal is */}}
# {{- /* prompted once and cached. */}}
# {{- $name := "Tyler Vick" }}
# {{- $email := "" }}
# {{- $signingKey := "" }}
# {{- if eq $profile "work" }}
# {{-   $email = "tyler.vick@functionhealth.com" }}
# {{-   $signingKey = "ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHqKXp5NtCzOEeMwZM5msGRy0Jga70SnM0H7JZ0WHtML" }}
# {{- else }}
# {{-   $email = promptStringOnce . "personal_email" "Personal git email" }}
# {{-   $signingKey = promptStringOnce . "personal_signing_key" "Personal git signing key (ssh-ed25519 ...)" }}
# {{- end }}

# {{- /* VM detection — handy for profile/host conditionals later. */}}
# {{- $hwModel := output "sysctl" "-n" "hw.model" | trim }}
# {{- $isVM := or (hasPrefix "VMware" $hwModel) (hasPrefix "VirtualMac" $hwModel) (hasPrefix "Parallels" $hwModel) }}

[data]
    profile = "{{ $profile }}"
    hostname = "{{ $hostname }}"
    is_vm = {{ $isVM }}
    name = "{{ $name }}"
    email = "{{ $email }}"
    signing_key = "{{ $signingKey }}"
{{- if ne $profile "work" }}
    # Persisted so promptStringOnce finds them on re-init (personal profile only).
    personal_email = "{{ $email }}"
    personal_signing_key = "{{ $signingKey }}"
{{- end }}
